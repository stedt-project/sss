# ============================================================================
# STEDT RootCanal – runtime environment variables
#
# Copy this file to rootcanal.env (in the project root, alongside
# docker-compose.yml), then fill in real values before running
# 'docker compose up'.
#
# rootcanal.env is listed in .gitignore so your credentials are never
# committed to the repository.
# ============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Name of the MariaDB database (should match the dump you loaded)
DB_NAME=stedt

# MariaDB username that the web app will use
DB_USER=stedt

# Password for DB_USER  ← CHANGE THIS
DB_PASS=changeme

# Optional: set a MariaDB root password inside the container.
# Leave blank to keep socket-only root access (safe inside the container).
DB_ROOT_PASS=

# ── Application ───────────────────────────────────────────────────────────────
# Set to 1 when NOT running HTTPS (e.g. behind a TLS-terminating proxy that
# doesn't forward the 'stsec' cookie, or during local testing).
# Set to 0 only when the container is directly serving HTTPS.
IGNORE_SSL=1
